{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "synapse-governance-ir-schema-v1",
  "title": "Synapse Governance Rule IR",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ir_version",
    "generated_from",
    "rules"
  ],
  "properties": {
    "ir_version": {
      "type": "string",
      "const": "1.0"
    },
    "generated_from": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      }
    }
  },
  "$defs": {
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "source_doc",
        "source_section",
        "statement",
        "modality",
        "enforcement_domain",
        "dependencies",
        "evidence_status"
      ],
      "properties": {
        "rule_id": {
          "type": "string",
          "pattern": "^[A-Z0-9_\\-]+$"
        },
        "source_doc": {
          "type": "string",
          "minLength": 1
        },
        "source_section": {
          "type": "string",
          "minLength": 1
        },
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "modality": {
          "type": "string",
          "enum": [
            "MUST",
            "MUST_NOT",
            "SHOULD",
            "MAY",
            "UNKNOWN"
          ]
        },
        "enforcement_domain": {
          "type": "string",
          "enum": [
            "governance_pack",
            "canonical_law",
            "governance_process",
            "locks",
            "terminology",
            "schema_validation",
            "continuity_governance",
            "quest_system",
            "talent_tree",
            "UNKNOWN"
          ]
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_status": {
          "type": "string",
          "enum": [
            "DIRECT",
            "INFERRED",
            "UNKNOWN"
          ]
        },
        "evidence_excerpt": {
          "type": "string"
        },
        "blocking_if_unmet": {
          "type": "string",
          "enum": [
            "YES",
            "NO",
            "UNKNOWN"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
